NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
AUTH_CALLBACK_PATH=/callback
AUTH_ERROR_PATH=/auth-error
AUTH_DEFAULT_RETURN_TO_PATH=/cabinet
AUTH_ALLOWED_REDIRECT_ORIGINS=http://127.0.0.1:3000

# Local Supabase CLI defaults. `pnpm supabase:env` prints the live values from the running stack.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Replace the three Supabase values above with hosted project credentials outside local CLI usage.
