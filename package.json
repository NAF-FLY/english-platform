{
  "name": "english-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "verify:auth": "node scripts/verify.mjs --supabase --auth-only",
    "verify:supabase": "node scripts/verify.mjs --supabase",
    "supabase:start": "pnpm exec supabase start --yes --exclude realtime,storage-api,imgproxy,edge-runtime,logflare,vector,supavisor",
    "supabase:stop": "pnpm exec supabase stop --yes",
    "supabase:status": "pnpm exec supabase status",
    "supabase:status:env": "pnpm exec supabase status -o env",
    "supabase:env": "node scripts/print-supabase-env.mjs",
    "supabase:reset": "pnpm exec supabase db reset --local --yes",
    "supabase:lint": "pnpm exec supabase db lint --local",
    "supabase:types": "pnpm exec supabase gen types typescript --local --schema public > src/lib/supabase/types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.9.0",
    "@supabase/supabase-js": "2.99.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "supabase": "2.78.1",
    "typescript": "5.9.3"
  }
}
